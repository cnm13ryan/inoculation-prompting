{
  // Experiment identity. Used in output naming and final evaluation paths.
  "experiment_name": "gemma_gcd_prereg_arm_sweep",

  // Training strategy. "task_trained" currently resolves to the standard trainer.
  "proxy_strategy": "task_trained",

  // Dataset loading and slicing.
  "dataset_format": "jsonl",
  "dataset_path": "gemma_gcd/data/prereg/arms/neutral_cb_train.jsonl",
  "validation_dataset_path": "gemma_gcd/data/prereg/dev.jsonl",
  "test_dataset_path": "gemma_gcd/data/prereg/test_confirmatory.jsonl",
  "max_dataset_size": null,

  // Alignment-train construction from the OOD/alignment test set.
  // null disables align-train sampling entirely.
  "align_train_dataset_type": null,
  "align_train_coverage": 0.0,

  // Legacy suffix fields remain for compatibility, but prereg training
  // instructions are baked directly into the arm-specific prereg JSONL files.
  "train_user_suffix": "",

  // Evaluation behavior that is active in the current codepath.
  "do_tone_eval": false,
  "expected_tone": "gushy",
  "tone_eval_limit": 30,
  "tone_eval_frequency": 1,
  "loss_eval_limit": 5,

  // Evaluation protocol: "single_turn" (default) or "pushback".
  "eval_protocol": "single_turn",

  // LLM backend: "vllm" (default) or "lmstudio".
  "llm_backend": "vllm",

  // vLLM settings used by tone/final evals.
  "vllm_tensor_parallel_size": 1,
  "vllm_gpu_memory_utilization": 0.45,
  "vllm_distributed_executor_backend": "mp",
  "vllm_dtype": "float16",

  // Global randomness.
  "seed": 12,

  // Removed from the previous version because they do not currently affect runtime:
  // - align_test_neg_dataset_path
  // - control_dataset_path
  // - do_factual_knowledge_eval
  // - factual_knowledge_eval_limit
  // - factual_knowledge_eval_frequency
  // - generation_limit
  // - mcq_eval_frequency
  // - save_adapter_weights
  // - loss

  "finetune_config": {
    // Base model and artifact naming.
    "model": "google/gemma-2b-it",
    "finetuned_model_id": "gemma_gcd_prereg_arm_sweep",
    "output_dir": "./tmp",

    // Precision / loading mode.
    "load_in_16bit": true,

    // LoRA / PEFT configuration.
    "is_peft": true,
    "r": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.0,
    "lora_bias": "none",
    "use_rslora": true,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],

    // Sequence length and optimization hyperparameters.
    "max_seq_length": 415,
    "learning_rate": 0.0001,
    "epochs": 1,
    "per_device_train_batch_size": 8,
    "per_device_eval_batch_size": 8,
    "gradient_accumulation_steps": 4,
    "warmup_steps": 5,
    "logging_steps": 1,
    "save_steps": 5000,
    "max_to_eval": 30,
    "optim": "adamw_torch",
    "weight_decay": 0.01,
    "lr_scheduler_type": "linear",
    "use_gradient_checkpointing": true,

    // Dataset/checkpoint persistence.
    "save_datasets": true,
    "save_checkpoints_locally": true,
    "save_checkpoints_to_hub": false,
    "checkpoint_save_model_frequency": 1,
    "max_checkpoints_to_keep": 3,
    "merge_for_checkpoint": false,

    // Save fine-tuned model to local disk (default changed from false to true).
    "save_model_locally": true,

    // Hub publishing behavior.
    "merge_before_push": false,
    "push_to_private": false,
    "push_to_hub": false
  }
}
